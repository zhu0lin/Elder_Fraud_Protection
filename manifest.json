{
    "name": "Elder Fraud Protection",
    "description": "Base Level Extension",
    "version": "1.0",
    "manifest_version": 3,

    "icons": {
      "16": "icons/icon-favicon.png"
    },

    "action": {
      "default_popup": "popup/popup.html",
      "default_icon": "icons/icon-favicon.png"
    },
    
    "content_scripts":[
      {
        "matches":["<all_urls>"],
        "js":["content.js"]
      }
    ],
    
    "background":{
      "service_worker":"background.js"
    },
    "permissions":["activeTab","scripting","tabs"]
  }